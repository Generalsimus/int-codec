{
  "compilerOptions": {
    "moduleResolution": "node",
    "noImplicitAny": true,
    "removeComments": false,
    "preserveConstEnums": true,
    "sourceMap": true,
    "declaration": true,
    "target": "ES2020",
    "isolatedModules": true,
    "skipLibCheck": true,
    "rootDir": "./",
    "declarationDir": "./dist",
    "outDir": "./dist",
    "strict": true,
  },
  "exclude": [
    "./dist/",
    "node_modules",
    "./test"
  ]
}